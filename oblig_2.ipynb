   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "iterations = 500\n",
    "\n",
    "x = 0.0\n",
    "\n",
    "def fn(x):\n",
    "    return np.exp(-x/4.0) * np.arctan(x) \n",
    "\n",
    "def der_fn(x):\n",
    "    return ((8 * x) / (x**2 + 1)**2) + 1 / (x**2 + 1) \n",
    "\n",
    "for i in range(iterations):\n",
    "    x = x - fn(x)/der_fn(x)\n",
    "\n",
    "print(x)\n"
   ]
